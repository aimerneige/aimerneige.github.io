&lt;h2 id="较常用的检索限制">较常用的检索限制&lt;/h2>
&lt;p>项目名称&lt;/p>
&lt;pre tabindex="0">&lt;code>in:name &amp;lt;keyword&amp;gt;
&lt;/code>&lt;/pre>&lt;p>项目 README&lt;/p>
&lt;pre tabindex="0">&lt;code>in:readme &amp;lt;keyword&amp;gt;
&lt;/code>&lt;/pre>&lt;p>项目描述&lt;/p>
&lt;pre tabindex="0">&lt;code>in:description &amp;lt;keyword&amp;gt;
&lt;/code>&lt;/pre>&lt;p>语言&lt;/p>
&lt;pre tabindex="0">&lt;code>language: java
&lt;/code>&lt;/pre>&lt;p>star 数&lt;/p>
&lt;pre tabindex="0">&lt;code>stars:&amp;gt;1000
&lt;/code>&lt;/pre>&lt;p>fork 数&lt;/p>
&lt;pre tabindex="0">&lt;code>forks:&amp;gt;500
&lt;/code>&lt;/pre>&lt;p>更新时间&lt;/p>
&lt;pre tabindex="0">&lt;code>pushed:&amp;gt;2020-08-01
&lt;/code>&lt;/pre>&lt;p>使用示例&lt;/p>
&lt;pre tabindex="0">&lt;code>in:name marp in:description theme stars:&amp;gt;5 pushed:&amp;gt;2020-01-01
&lt;/code>&lt;/pre>&lt;blockquote>
